{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"URL": "https://github.com/danilapisarev/streamdeck-sonos-volume",
	"UUID": "com.danila.sonos-volume",
	"Name": "Volume for AirPlay Sonos",
	"Version": "1.0.2.0",
	"Author": "Danila Pisarev",
	"Actions": [
		{
			"Name": "Volume Up",
			"UUID": "com.danila.sonos-volume.up",
			"Icon": "imgs/actions/volumeup",
			"Tooltip": "Increase the volume of a Sonos speaker",
			"PropertyInspectorPath": "ui/volume-settings.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/volumeup_key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Volume Down",
			"UUID": "com.danila.sonos-volume.down",
			"Icon": "imgs/actions/volumedown",
			"Tooltip": "Decrease the volume of a Sonos speaker",
			"PropertyInspectorPath": "ui/volume-settings.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/volumedown_key",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"Name": "Play / Pause",
			"UUID": "com.danila.sonos-volume.playpause",
			"Icon": "imgs/actions/playpause",
			"Tooltip": "Toggle play/pause on a Sonos speaker",
			"PropertyInspectorPath": "ui/playpause-settings.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/playpause_key",
					"TitleAlignment": "bottom"
				}
			]
		}
	],
	"Category": "Volume for AirPlay Sonos",
	"CategoryIcon": "imgs/actions/volumeup",
	"CodePath": "bin/plugin.js",
	"Description": "Control your AirPlay-connected Sonos speakers from Stream Deck: Volume Up / Down keys with a live volume bar, plus a Play/Pause key that shows what's playing. Auto-discovers speakers on your network. Not affiliated with, or endorsed by, Sonos.",
	"Icon": "imgs/plugin/icon",
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	},
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "12"
		},
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "20"
	}
}